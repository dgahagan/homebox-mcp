# Copy to .env (gitignored, chmod 600) and fill in.
#
# Create an API key in Homebox: Profile → API Keys, or
#   POST /api/v1/users/self/api-keys  {"name": "homebox-mcp"}

# Base URL of your Homebox instance (no trailing slash).
HOMEBOX_URL=http://localhost:7745

# Homebox API key (starts with hb_).
HOMEBOX_TOKEN=hb_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional -------------------------------------------------------------

# Name of one custom field used as a stable item identifier: tools resolve
# items by it and field_index() defaults to it. Unset = resolve by
# assetId/name only.
#HOMEBOX_ALIAS_FIELD=item_id

# Directory where generate_label / qrcode save PNG/JPEG output.
# Default: current working directory.
#HOMEBOX_LABEL_DIR=~/homebox-labels
